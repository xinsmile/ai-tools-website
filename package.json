{
  "name": "aibox",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm --filter aibox-backend dev\" \"pnpm --filter aibox-frontend dev\"",
    "dev:frontend": "pnpm --filter aibox-frontend dev",
    "dev:backend": "pnpm --filter aibox-backend dev",
    "build": "pnpm --filter aibox-backend build && pnpm --filter aibox-frontend build",
    "build:frontend": "pnpm --filter aibox-frontend build",
    "build:backend": "pnpm --filter aibox-backend build",
    "start": "pnpm --filter aibox-backend start",
    "lint": "pnpm --filter aibox-frontend lint"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
